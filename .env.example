# ------------------------------------------------------------------------------
# This is an example .env file.
#
# All of these environment vars must be defined either in your environment or in
# a local .env file in order to run this app.
# ------------------------------------------------------------------------------

# Set to "production" in the deploy environment so robots.txt allows indexing
# and the site advertises itself for crawl. Anything else (or unset) emits a
# disallow-all robots.txt — useful for preview deploys.
#BUILD_ENV=production
